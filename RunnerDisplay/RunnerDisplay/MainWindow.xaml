<Window x:Class="RunnerDisplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RunnerDisplay"
        mc:Ignorable="d"
        Title="Runner Display" Height="500" Width="750">

    <Grid Background="#FFEFEB">
        <Grid.RowDefinitions>
            <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Notifications -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Grid Grid.Row="0" Margin="20,15,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <TextBlock
                Grid.Column="0"
                Text="RUNNER DISPLAY"
                FontSize="30"
                FontFamily="Consolas"
                FontWeight="Bold"
                Foreground="#995C68"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"/>

            <!-- Notification Status -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">

                <!-- Status Dot -->
                <Ellipse
                    Name="NotificationDot"
                    Width="15"
                    Height="15"
                    Fill="gray"
                    Margin="0,0,10,0"/>

                    <TextBlock
                    Text="Bins need refilling!"
                    FontSize="16"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    Foreground="#6D6875"
                    VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ================= NOTIFICATION LIST ================= -->
        <DataGrid Grid.Row="1"
                  Name="NotificationGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="20"
                  Background="#B5838D"
                  FontFamily="Lucida Console"
                  FontSize="12"
                  BorderThickness="0"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  SelectionMode="Single">

            <DataGrid.Columns>

                <!-- Status Dot Column -->
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Part Name" Binding="{Binding PartName}" Width="*"/>
                <DataGridTextColumn Header="Bin ID" Binding="{Binding BinID}" Width="*"/>
                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*"/>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding TimeStamp}" Width="2*"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ================= FOOTER BUTTONS ================= -->
        <Grid Grid.Row="2" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Close Button (Left) -->
            <Button
                Grid.Column="0"
                Name="CloseButton"
                Click="CloseButton_Click"
                Content="CLOSE"
                Width="120"
                Height="35"
                Background="#6D6875"
                Foreground="#FFEFEB"
                FontSize="18"
                FontFamily="Consolas"
                FontWeight="Bold"
                BorderThickness="0"
                HorizontalAlignment="Left"/>

            <!-- Start/Stop Buttons (Right) -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                <Button 
                    Name="StartButton"
                    Click="StartButton_Click"
                    Content="START"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    FontSize="18"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    BorderThickness="2"
                    BorderBrush="#6D6875"
                    Background="#CCD5AE"
                    Foreground="#6D6875"
                    IsEnabled="True"/>

                <Button 
                    Name="StopButton"
                    Click="StopButton_Click"
                    Content="STOP"
                    Width="120"
                    Height="35"
                    FontSize="18"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    BorderThickness="2"
                    BorderBrush="#6D6875"
                    Background="#E5989B"
                    Foreground="#6D6875"
                    IsEnabled="False"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
