<!--
    FILE          : App.config
    PROJECT       : Project ManufacturingP01 - ConfigTool (Milestone 1)
    PROGRAMMER    : Bibi Murwared
    FIRST VERSION : 2026-03-11
    DESCRIPTION   : Connection string settings for the Jubi SQL Server database,used by the WPF Config Tool to read and
                    update the Configuration table.
-->
<configuration>
	<connectionStrings>
		<add name="JubiConnection"
			 connectionString="Server=localhost;Database=Jubi;Trusted_Connection=True;TrustServerCertificate=True;"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>
