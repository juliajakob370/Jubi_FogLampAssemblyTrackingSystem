<!--
    FILE          : MainWindow.xaml
    PROJECT       : Project ManufacturingP01 - ConfigTool (Milestone 1)
    PROGRAMMER    : Julia Jakob
    FIRST VERSION : 2026-03-10
    DESCRIPTION   : Main window XAML for the config tool
    UPDATED BY    : Bibi Murwared (2026-03-11): added explicit column definitions (ID,Name, Value, Type, description) so
                    configuration settings are clearly displayed and can be edited if wanted.
    -->
    <Window x:Class="P01_ConfigTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P01_ConfigTool"
        mc:Ignorable="d"
        Title="ConfigTool" Height="500" Width="600" ResizeMode="CanResize">
    <Grid Background="#FFEFEB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                   Name="ResetToDefaultsButton"
                   Click="ResetToDefaults_Click"
                   Background="Transparent"
                   Foreground="#995C68"
                   Content="🔄️"
                   FontSize="50"
                   FontFamily="Consolas"
                   BorderThickness="0"
                   Margin="0,20,0,0"
                   ToolTip="Reset values to defaults!"
                   />
            <TextBlock Grid.Column="1"
                       Name="TitleText"
                       FontSize="30"
                       FontFamily="Consolas"
                       FontWeight="Bold"
                       Text="CONFIG TOOL"
                       Margin="0,20,0,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#995C68"/>
            <Button Grid.Column="2"
                    Name="AddButton"
                    Click="AddConfiguration_Click"
                    Background="Transparent"
                    Foreground="#995C68"
                    Content="✚"
                    FontSize="50"
                    FontFamily="Consolas"
                    BorderThickness="0"
                    Margin="0,20,0,0"
                    ToolTip="Add Configuration!"
                    />

        </Grid>

        <DataGrid Grid.Row="1"
   Name="ConfigurationsDisplay"
   AutoGenerateColumns="False"
   CanUserAddRows="False"
   SelectionMode="Single"
   SelectionChanged="ConfigurationsDisplay_SelectionChanged"
   Padding="10"
   Background="#B5838D"
   Margin="20"
   ScrollViewer.VerticalScrollBarVisibility="Auto"
   ScrollViewer.HorizontalScrollBarVisibility="Auto"
   FontSize="12"
   FontFamily="Lucida Console"
   BorderThickness="0">

            <!-- Add this minimal wrapping style -->
            <DataGrid.Resources>
                <Style x:Key="WrappingTextBlock" TargetType="TextBlock">
                    <Setter Property="TextWrapping" Value="Wrap" />
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ConfigID}" Width="50" SortDirection="Ascending"/>

                <DataGridTextColumn Header="Name" Binding="{Binding ConfigName}" Width="1*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource WrappingTextBlock}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Value" Binding="{Binding ConfigValue}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding DataType}" Width="*"/>

                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource WrappingTextBlock}"/>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>


        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Name="Close"
                    Click="Close_Click"
                    Background="#6D6875"
                    Foreground="#FFEFEB"
                    Content="CLOSE"
                    FontSize="20"
                    Height="35"
                    Width="100"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    BorderThickness="0"
                    Margin="0,0,0,20"
                    ToolTip="Close config tool"
                    />
            <Button Grid.Column="2"
                    Name="DeleteButton"
                    Click="Delete_Click"
                    Background="#FFEFEB"
                    Foreground="#E5989B"
                    BorderBrush="#E5989B"
                    Content="🗑️"
                    FontSize="20"
                    Height="35"
                    Width="60"
                    HorizontalAlignment="Left"
                    FontFamily="Consolas"
                    BorderThickness="3"
                    Margin="0,0,0,20"
                    ToolTip="Delete Selected Row"
                    IsEnabled="False"
                    />
            <Button Grid.Column="2"
                    Name="SaveButton"
                    Click="Save_Click"
                    Background="#6D6875"
                    Foreground="#FFEFEB"
                    Content="SAVE"
                    FontSize="20"
                    Height="35"
                    Width="100"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    BorderThickness="0"
                    Margin="0,0,0,20"
                    ToolTip="Save Configurations"
                    />
        </Grid>
    </Grid>
</Window>
