<Window x:Class="P01_WorkstationSimulation.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:P01_WorkstationSimulation"
    mc:Ignorable="d"
    Title="MainWindow" Height="450" Width="700">

    <Grid Background="#FFEFEB">
        <Grid.RowDefinitions>
            <!-- 0 Title Row -->
            <RowDefinition Height="2*"/>
            <!-- 1 Worker Row -->
            <RowDefinition Height="1*"/>
            <!-- 2 Workstation Row -->
            <RowDefinition Height="1*"/>
            <!-- 3 Buttons Row -->
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Grid Grid.Row="0">
            <TextBlock
                Name="TitleText"
                FontSize="40"
                FontFamily="Consolas"
                FontWeight="Bold"
                Text="WORKSTATION SIMULATOR"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="#995C68"/>

            <Button
                Name="CloseButton"
                Click="CloseButton_Click"
                Background="Transparent"
                Foreground="#995C68"
                Content="❌"
                FontSize="30"
                FontFamily="Consolas"
                BorderThickness="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,20,0"
                ToolTip="Close Station"/>
        </Grid>

        <!-- Worker Selection -->
        <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock  
                Grid.Column="0"
                Name="WorkerSelectLabel"
                FontSize="20"
                FontFamily="Consolas"
                FontWeight="Bold"
                Text="Select Worker:"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="#6D6875"/>

            <ComboBox   
                Grid.Column="1"
                Name="WorkerSelect"
                SelectionChanged="WorkerSelect_SelectionChanged"
                Height="25"
                Width="200"
                Margin="20,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#FFCDB2"
                Foreground="#6D6875"
                FontWeight="SemiBold"
                FontFamily="Consolas"/>
        </Grid>

        <!-- Workstation Selection -->
        <Grid Grid.Row="2" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock  
                Grid.Column="0"
                Name="WorkstationSelectLabel"
                FontSize="20"
                FontFamily="Consolas"
                FontWeight="Bold"
                Text="Select Workstation:"
                Margin="0,0,20,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="#6D6875"/>

            <ComboBox   
                Grid.Column="1"
                Name="WorkstationSelect"
                SelectionChanged="WorkstationSelect_SelectionChanged"
                Height="25"
                Width="200"
                Margin="20,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#FFCDB2"
                Foreground="#6D6875"
                FontWeight="SemiBold"
                FontFamily="Consolas"/>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="3" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button 
                Grid.Column="0"
                Name="StartButton"
                Click="StartButton_Click"
                Height="35"
                Width="150"
                Content="Start"
                FontSize="20"
                FontFamily="Consolas"
                FontWeight="Bold"
                BorderThickness="2"
                BorderBrush="#6d6875"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#ccd5ae"
                Foreground="#6d6875"
                IsEnabled="False"/>

            <Button 
                Grid.Column="1"
                Name="StopButton"
                Click="StopButton_Click"
                Height="35"
                Width="150"
                Content="Stop"
                FontSize="20"
                FontFamily="Consolas"
                FontWeight="Bold"
                BorderThickness="2"
                BorderBrush="#6d6875"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#e5989b"
                Foreground="#6d6875"
                IsEnabled="False"/>
        </Grid>

    </Grid>
</Window>