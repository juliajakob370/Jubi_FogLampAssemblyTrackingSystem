    DESCRIPTION   : Main window XAML for the workstation simulation tool
    -->
    <Window x:Class="P01_WorkstationSimulation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P01_WorkstationSimulation"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="700">
    <Grid Background="#FFEFEB">
        <Grid.RowDefinitions>
            <!-- 0 Title Row -->
            <RowDefinition Height="Auto"/>
            <!-- 1 Stopwatch Row -->
            <RowDefinition Height="Auto"/>
            <!-- 2 Worker Row -->
            <RowDefinition Height="Auto"/>
            <!-- 3 Workstation Row -->
            <RowDefinition Height="Auto"/>
            <!-- 4 Buttons Row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
            Name="TitleText"
            FontSize="40"
            FontFamily="Consolas"
            FontWeight="Bold"
            Text="WORKSTATION SIMULATOR"
            Margin="0,20,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="#995C68"/>
        <Button Grid.Row="0"
                   Name="CloseButton"
                   Click="CloseButton_Click"
                   Background="Transparent"
                   Foreground="#995C68"
                   Content="❌"
                   FontSize="30"
                   FontFamily="Consolas"
                   BorderThickness="0"
                   HorizontalAlignment="Right"
                   Margin="0,20,20,0"
                   ToolTip="Close Station"
                   />
        <TextBlock Grid.Row="1"
                   Name="StopwatchDisplay"
                   FontSize="80"
                   FontFamily="Consolas"
                   FontWeight="Bold"
                   Text="00:00"
                    Margin="0,40,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="#6D6875"/>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock  Grid.Column="0"
                        Name="WorkerSelectLabel"
                        FontSize="20"
                        FontFamily="Consolas"
                        FontWeight="Bold"
                        Text="Select Worker:"
                        Margin="0,40,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="#6D6875"/>  

            <ComboBox   Grid.Column="1"
                        Name="WorkerSelect"
                        Height="20"
                        Width="200"
                        Margin="20,40,0,0"
                        HorizontalAlignment="Left"/>

        </Grid>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock  Grid.Column="0"
                        Name="WorkstationSelectLabel"
                        FontSize="20"
                        FontFamily="Consolas"
                        FontWeight="Bold"
                        Text="Select Workstation:"
                        Margin="0,30,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="#6D6875"/>

            <ComboBox   Grid.Column="1"
                        Name="WorkstationSelect"
                        SelectionChanged="WorkstationSelect_SelectionChanged"
                        Height="20"
                        Width="200"
                        Margin="20,30,0,0"
                        HorizontalAlignment="Left"/>

        </Grid>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Name="StartButton"
                    Click="StartButton_Click"
                    Height="30"
                    Width="150"
                    Content="Start"
                    FontSize="20"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    BorderThickness="2"
                    BorderBrush="#6d6875"
                    Margin="20,40,0,0"
                    HorizontalAlignment="Center"
                    Background="#ccd5ae"
                    Foreground="#6d6875"/>
            
            <Button Grid.Column="1"
                    Name="StopButton"
                    Click="StopButton_Click"
                    Height="30"
                    Width="150"
                    Content="Stop"
                    FontSize="20"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    BorderThickness="2"
                    BorderBrush="#6d6875"
                    Margin="20,40,0,0"
                    HorizontalAlignment="Center"
                    Background="#e5989b"
                    Foreground="#6d6875"
                    IsEnabled="False"/>
        </Grid>

    </Grid>
</Window>
